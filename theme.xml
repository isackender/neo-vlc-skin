							<SliderBackground id="slider_track_bg" image="track_middle_bg" nbvert="480" />
            </Slider>
						<!-- Media track slider END -->
					</Panel>
					<Panel id="panel_media_end_time" x="540" width="60" height="36" lefttop="rightbottom" rightbottom="rightbottom">
