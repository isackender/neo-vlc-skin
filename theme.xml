							tooltiptext1="Shuffle off"
							tooltiptext2="Shuffle on"
							x="126"
						/>
						<Button up="playlist_active_up" down="playlist_down" over="playlist_active_hover" action="Player.setLayout(Main)" id="btn_playlist" x="150" lefttop="leftbottom" rightbottom="leftbottom" help="Playlist" tooltiptext="Playlist"/>
					</Panel>
					<!-- Media controls END -->
					<!-- Media artist START -->
					<Panel id="panel_media_artist" width="236" height="24" x="200" lefttop="leftbottom" rightbottom="rightbottom">
						<Text text="$N" font="silver-20" alignment="center" color="#FFFFFF" y="3" id="media_playing_title" width="232" lefttop="leftbottom" rightbottom="rightbottom" xkeepratio="false"/>
					</Panel>
					<!-- Media artist END -->
					<!-- Volume START -->
					<Panel id="panel_media_controls_b" width="160" height="24" x="436" lefttop="rightbottom" rightbottom="rightbottom">
						<Checkbox id="mute_toggle" state="vlc.isMute"
							up1="volume-on_up" over1="volume-on_hover" down1="volume-on_down" action1="vlc.mute()"
							up2="volume-off_up" over2="volume-off_hover" down2="volume-off_down" action2="vlc.mute()"
							tooltiptext1="Sound off"
							tooltiptext2="Sound on"
							x="0"
						/>
						<Slider id="slider_volume" x="32" y="6" points="(0,6),(72,6)" value="volume"
							up="slider_thumb_h" width="72" lefttop="rightbottom" rightbottom="rightbottom">
							<SliderBackground id="slider_volume_bg" image="volume_track_bg"/>
            </Slider>
						<Text text="$V%" font="silver-18" alignment="left" color="#FFFFFF" x="112" y="4" id="text_volume" width="36" lefttop="rightbottom" rightbottom="rightbottom"/>
					</Panel>
					<!-- Volume END -->
				</Panel>
				<!-- Panel for media controls END -->
			</Panel>
			<!-- Panel for media END -->
			<!-- Panel for playlist START -->
			<Panel id="panel_playlist" x="350" y="24" width="250" height="288" lefttop="righttop" rightbottom="rightbottom">
				<Image id="img_playlist_bg" width="350" height="288" image="hidden-resizer" lefttop="lefttop" rightbottom="rightbottom"/>
				<Playtree id="playlist" font="silver-20"
					x="16"
					width="230" height="264" lefttop="righttop" rightbottom="rightbottom"
					flat="true"
					bgcolor1="#000000" bgcolor2="#000000" selcolor="#1a1a1a"
					playcolor="#FF0000" fgcolor="#FFFFFF"
				>
					<Slider id="slider_playlist" width="12" height="288" lefttop="righttop" rightbottom="rightbottom"
						points="(2,282),(2,6)" up="slider_thumb_h" thickness="12"
						bgcolor="#000000"/>
				</Playtree>
				<Panel id="panel_playlist_controls" x="0" y="264" width="250" height="24" lefttop="leftbottom" rightbottom="rightbottom">
					<Button id="plus" up="plus_up" down="plus_down" over="plus_hover" action="playlist.add()"
					x="16"
					lefttop="leftbottom" rightbottom="leftbottom" help="Add to the playlist" tooltiptext="Add to the playlist"/>
					<Button id="minus" up="minus_up" down="minus_down" over="minus_hover" action="playlist.del()"
					x="40"
					lefttop="leftbottom" rightbottom="leftbottom" help="Remove selected from the playlist" tooltiptext="Remove selected from the playlist"/>
				</Panel>
			</Panel>
			<!-- Panel for playlist END -->
			<!-- Window resizers START -->
			<Panel id="panel_window_resizer_w" width="4" height="364" y="24" lefttop="lefttop" rightbottom="leftbottom">
				<!-- This is not a resizer, only keeps symmetry -->
				<Image id="img_resizer_w" width="4" height="368" image="hidden-resizer" action="resizeW" lefttop="lefttop" rightbottom="rightbottom"/>
			</Panel>
			<Panel id="panel_window_resizer_se" width="600" height="16" y="372" lefttop="leftbottom" rightbottom="rightbottom">
				<Image id="img_resizer_se" width="12" height="12" x="588" y="4" image="resizer" action="resizeSE" lefttop="rightbottom" rightbottom="rightbottom"/>
			</Panel>
			<Panel id="panel_window_resizer_s" width="588" height="4" y="384" lefttop="leftbottom" rightbottom="rightbottom">
				<Image id="img_hidden-resizer_s" width="588" height="4" image="hidden-resizer" action="resizeS" lefttop="leftbottom" rightbottom="rightbottom"/>
			</Panel>
			<Panel id="panel_window_resizer_e" width="4" height="352" x="596" y="24" lefttop="righttop" rightbottom="rightbottom">
				<Image id="img_hidden-resizer_e" width="4" height="352" image="hidden-resizer" action="resizeE" lefttop="righttop" rightbottom="rightbottom"/>
			</Panel>
			<!-- Window resizers END -->
    </Layout>
		<!-- Windowed playlist layout -->
  </Window>

</Theme>