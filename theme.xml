							up1="shuffle_up"
							up2="shuffle_active"
							over1="shuffle_hover"
							over2="shuffle_active_hover"
							down1="shuffle_down"
							down2="shuffle_down"
							action1="playlist.setRandom(true)"
							action2="playlist.setRandom(false)"
							tooltiptext1="Shuffle off"
							tooltiptext2="Shuffle on"
							x="126"
						/>
