							id="current_time_placeholder" x="12" y="10" width="40" lefttop="leftbottom" rightbottom="leftbottom"
							visible="(not vlc.hasAudio) and (not vlc.hasVout)"
						/>
						<Text text="$t" font="silver-18" alignment="right" color="#FFFFFF"
							id="current_time" x="12" y="10" width="40" lefttop="leftbottom" rightbottom="leftbottom"
							visible="vlc.isPlaying or vlc.hasAudio or vlc.hasVout"
						/>
					</Panel>
					<Panel id="panel_media_track_time" x="60" width="480" height="36" lefttop="leftbottom" rightbottom="rightbottom">
						<!-- Media track slider START -->
						<Slider id="slider_track" x="0" y="12" points="(0,6),(480,6)" thickness="0" value="time" tooltiptext=""
