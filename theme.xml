							up1="loop_up" down="loop_down" over1="loop_hover"
							up2="loop_active" down2="loop_down" over2="loop_active_hover"
							action1="playlist.setLoop(true)"
							action2="playlist.setLoop(false);playlist.setRepeat(true)"
